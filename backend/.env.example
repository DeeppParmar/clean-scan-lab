# ─── EcoLens Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values

# App
APP_ENV=development
LOG_LEVEL=INFO

# Supabase
SUPABASE_URL=https://uoffgokuvzndzgrfnfgm.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Model
MODEL_PATH=yolov8n-seg.pt
YOLO_CONF=0.6
YOLO_IOU=0.5

# Storage
MAX_IMAGE_SIZE_MB=10
SCAN_RESULTS_BUCKET=scan-results
HEATMAPS_BUCKET=heatmaps

# Rate limiting
ANALYZE_RATE_LIMIT=30/minute
MAX_WS_CONNECTIONS=4
