# ─── EcoLens Environment Variables ──────────────────────────────────────────

# App
APP_ENV=development
LOG_LEVEL=INFO

# Supabase
SUPABASE_URL= # Supabase Url
SUPABASE_KEY= # Publishable key
SUPABASE_SERVICE_KEY= # Your Supabse Service Key 
MAX_IMAGE_SIZE_MB=10

# Model
MODEL_PATH=yolov8n-seg.pt
YOLO_CONF=0.6
YOLO_IOU=0.5

# Rate limiting
ANALYZE_RATE_LIMIT=30/minute
MAX_WS_CONNECTIONS=4
